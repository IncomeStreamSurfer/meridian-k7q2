---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  structuredData?: object | object[];
  bodyClass?: string;
}

const { title, description, ogType, structuredData, bodyClass = '' } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <SEOHead title={title} description={description} ogType={ogType} structuredData={structuredData} />
  </head>
  <body class={`grain min-h-screen flex flex-col ${bodyClass}`}>
    <header class="border-b hairline">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <span class="relative inline-block w-8 h-8">
            <svg viewBox="0 0 64 64" class="w-full h-full">
              <circle cx="32" cy="32" r="22" fill="none" stroke="currentColor" stroke-width="1.5" />
              <line x1="32" y1="6" x2="32" y2="58" stroke="currentColor" stroke-width="1" />
              <line x1="6" y1="32" x2="58" y2="32" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
            </svg>
          </span>
          <span class="font-display text-2xl tracking-tight">Meridian</span>
        </a>
        <nav class="hidden md:flex items-center gap-8 text-sm">
          <a href="/" class="hover:text-amber transition">Waitlist</a>
          <a href="/about" class="hover:text-amber transition">Story</a>
          <a href="/#sourcing" class="hover:text-amber transition">Sourcing</a>
          <a href="/#ritual" class="hover:text-amber transition">Ritual</a>
        </nav>
        <a href="/#join" class="hidden sm:inline-flex items-center gap-2 text-sm font-mono uppercase tracking-widest border hairline px-4 py-2 hover:bg-amber hover:text-ink hover:border-amber transition">
          Join
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t hairline mt-24">
      <div class="max-w-6xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-10 text-sm">
        <div>
          <p class="font-display text-2xl mb-2">Meridian</p>
          <p class="opacity-70">Specialty coffee, sourced with intention. Launching late 2026.</p>
        </div>
        <div>
          <p class="font-mono uppercase text-xs tracking-widest opacity-60 mb-3">Explore</p>
          <ul class="space-y-2">
            <li><a href="/" class="hover:text-amber">Home</a></li>
            <li><a href="/about" class="hover:text-amber">Our Story</a></li>
            <li><a href="/#join" class="hover:text-amber">Join the Waitlist</a></li>
          </ul>
        </div>
        <div>
          <p class="font-mono uppercase text-xs tracking-widest opacity-60 mb-3">The Note</p>
          <p class="opacity-70">Quiet emails about origins, releases, and the rituals worth keeping. No noise.</p>
        </div>
      </div>
      <div class="border-t hairline">
        <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs opacity-60">
          <p>© 2026 Meridian Coffee Co. All rights reserved.</p>
          <p class="font-mono">N 51° 30' &nbsp;·&nbsp; W 0° 7'</p>
        </div>
      </div>
    </footer>
  </body>
</html>
